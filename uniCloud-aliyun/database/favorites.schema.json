{
  "bsonType": "object",
  "required": ["user_id", "card_id"],
  "permission": {
    "read": "auth.uid == doc.user_id",
    "create": "auth.uid != null",
    "update": false,
    "delete": "auth.uid == doc.user_id"
  },
  "properties": {
    "_id": {
      "description": "收藏记录ID"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户ID",
      "foreignKey": "users._id"
    },
    "card_id": {
      "bsonType": "string",
      "description": "卡片ID",
      "foreignKey": "cards._id"
    },
    "create_time": {
      "bsonType": "timestamp",
      "description": "收藏时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
