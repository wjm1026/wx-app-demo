{
  "bsonType": "object",
  "required": ["user_id", "type", "amount"],
  "permission": {
    "read": "auth.uid == doc.user_id || 'admin' in auth.role",
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "流水ID"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户ID",
      "foreignKey": "users._id"
    },
    "type": {
      "bsonType": "string",
      "description": "类型",
      "enum": ["invite", "ad_reward", "sign_in", "consume", "refund", "gift", "admin_add", "admin_deduct"]
    },
    "amount": {
      "bsonType": "int",
      "description": "变动数量（正增负减）"
    },
    "balance": {
      "bsonType": "int",
      "description": "变动后余额"
    },
    "description": {
      "bsonType": "string",
      "description": "描述"
    },
    "operator_id": {
      "bsonType": "string",
      "description": "操作管理员ID"
    },
    "related_id": {
      "bsonType": "string",
      "description": "关联ID（如被邀请人ID、卡片ID等）"
    },
    "create_time": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
