{
  "bsonType": "object",
  "required": ["openid"],
  "permission": {
    "read": "auth.uid == doc._id || 'admin' in auth.role",
    "create": false,
    "update": "auth.uid == doc._id",
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "用户ID"
    },
    "openid": {
      "bsonType": "string",
      "description": "微信openid"
    },
    "unionid": {
      "bsonType": "string",
      "description": "微信unionid"
    },
    "nickname": {
      "bsonType": "string",
      "description": "昵称",
      "trim": "both"
    },
    "avatar": {
      "bsonType": "string",
      "description": "头像URL"
    },
    "gender": {
      "bsonType": "int",
      "description": "性别 0未知 1男 2女",
      "enum": [0, 1, 2],
      "defaultValue": 0
    },
    "points": {
      "bsonType": "int",
      "description": "积分余额",
      "defaultValue": 0,
      "minimum": 0
    },
    "free_views": {
      "bsonType": "int",
      "description": "免费查看次数",
      "defaultValue": 5,
      "minimum": 0
    },
    "invite_code": {
      "bsonType": "string",
      "description": "我的邀请码"
    },
    "inviter_id": {
      "bsonType": "string",
      "description": "邀请人ID",
      "foreignKey": "users._id"
    },
    "invite_count": {
      "bsonType": "int",
      "description": "邀请人数",
      "defaultValue": 0
    },
    "is_vip": {
      "bsonType": "bool",
      "description": "是否VIP",
      "defaultValue": false
    },
    "vip_expire_time": {
      "bsonType": "timestamp",
      "description": "VIP过期时间"
    },
    "create_time": {
      "bsonType": "timestamp",
      "description": "注册时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    },
    "update_time": {
      "bsonType": "timestamp",
      "description": "更新时间"
    },
    "last_login_time": {
      "bsonType": "timestamp",
      "description": "最后登录时间"
    }
  }
}
