{
  "bsonType": "object",
  "required": ["user_id", "achievement_id", "unlock_time"],
  "permission": {
    "read": "auth.uid == doc.user_id || 'admin' in auth.role",
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "成就记录ID，建议使用 achievement:{user_id}:{achievement_id} 作为确定性主键"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户ID",
      "foreignKey": "users._id"
    },
    "achievement_id": {
      "bsonType": "string",
      "description": "成就ID"
    },
    "points": {
      "bsonType": "int",
      "description": "解锁该成就获得的积分",
      "minimum": 0
    },
    "unlock_time": {
      "bsonType": "timestamp",
      "description": "解锁时间"
    },
    "create_time": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
